generator client {
  provider = "prisma-client-js"
}

// LOCAL: DATABASE_URL="file:./dev.db" requires temporarily switching provider to "sqlite".
// PRODUCTION (Vercel/Neon): DATABASE_URL="postgresql://..." with provider="postgresql".
// Current provider is set for PRODUCTION. Prefer a local PostgreSQL/Neon URL for dev.
datasource db {
  // Local: use a local PostgreSQL URL. Production: postgresql://... (Neon, set in Vercel)
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserUsage {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  address       String?  @unique
  freeScansUsed Int      @default(0)
  scanCount     Int      @default(0)
  totalScans    Int      @default(0)
  huntCount     Int      @default(0)
  lastScanAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model InstantScan {
  id          String   @id @default(cuid())
  userAddress String
  address     String?
  packageName String
  version     String
  packageVersion String?
  scanDepth   String
  paid        Boolean  @default(false)
  isPaid      Boolean  @default(false)
  amountPaid  String?
  paymentTx   String?
  proofTx     String?
  proofTxHash String?
  scanId      String   @unique
  proofHash   String?
  reportHash  String?
  reportJson  Json?
  proofAnchored Boolean @default(false)
  severity    String   @default("unknown")
  riskScore   Int?
  riskLevel   String?
  createdAt   DateTime @default(now())
}

model Hunt {
  id             String       @id @default(cuid())
  chainId        Int          @default(2368)
  chainHuntId    Int?         @unique
  onChainId      Int?         @unique
  creatorAddress String
  packageName    String
  version        String
  scanDepth      String
  rewardAmount   String
  stakeRequired  String
  stakeAmount    String?
  deadline       DateTime
  status         String       @default("Open")
  termsHash      String?
  metadataHash   String?
  createdTx      String?
  txHash         String?      @unique
  winnerAddress  String?
  settlementTx   String?
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  submissions    Submission[]
  agentJoins     AgentJoin[]
}

// Records on-chain stakeAndJoin events for DB-level stake verification
model AgentJoin {
  id           String   @id @default(cuid())
  huntId       String
  hunt         Hunt     @relation(fields: [huntId], references: [id])
  agentAddress String
  txHash       String?
  stakedAmount String?
  onChainStaked Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([huntId, agentAddress])
}

model Submission {
  id               String   @id @default(cuid())
  huntId           String
  hunt             Hunt     @relation(fields: [huntId], references: [id])
  agentAddress     String
  contractIndex    Int?     // 0-based on-chain submission array index
  stakeTx          String?
  reportHash       String?
  reportJson       Json?
  proofHash        String?
  txHash           String?
  status           String   @default("Submitted")
  verifierResult   Boolean?
  verifierReport   Json?
  verificationHash String?
  verificationTx   String?
  settlementTx     String?
  createdAt        DateTime @default(now())
  submittedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ChainEvent {
  id              String   @id @default(cuid())
  chainId         Int
  contractAddress String
  eventName       String
  txHash          String
  blockNumber     BigInt
  payloadJson     Json
  createdAt       DateTime @default(now())
}

model AgentProfile {
  address        String   @id
  totalSubmitted Int      @default(0)
  totalValid     Int      @default(0)
  totalInvalid   Int      @default(0)
  totalWon       Int      @default(0)
  totalEarned    String   @default("0")
  totalSlashed   String   @default("0")
  updatedAt      DateTime @updatedAt
}
