# -- KiteAI Network ---------------------------------------------------------
NEXT_PUBLIC_KITE_CHAIN_ID=2368
NEXT_PUBLIC_KITE_RPC_URL=https://rpc-testnet.gokite.ai/
NEXT_PUBLIC_KITE_EXPLORER=https://testnet.kitescan.ai
NEXT_PUBLIC_KITE_CHAIN_NAME=KiteAI Testnet

# -- Contracts (set automatically by deploy script) -------------------------
NEXT_PUBLIC_KITEBOND_CONTRACT=          # KiteBondHuntRegistry deployed address
NEXT_PUBLIC_SCAN_PAYMENTS_CONTRACT=     # KiteBondScanPayments deployed address
NEXT_PUBLIC_PAYMENT_TOKEN=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63
NEXT_PUBLIC_TEST_USDT_ADDRESS=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63

# -- Protocol Treasury ------------------------------------------------------
PROTOCOL_TREASURY=                      # 0x... production treasury. Dev fallback: deployer address.
NEXT_PUBLIC_PROTOCOL_TREASURY=          # same value for UI display

# -- Deployer ---------------------------------------------------------------
# Export from MetaMask. Fund with KITE: https://faucet.gokite.ai
DEPLOYER_PRIVATE_KEY=                   # 0x... NEVER COMMIT

# -- Verifier ---------------------------------------------------------------
# Server-side verifier wallet. Falls back to DEPLOYER_PRIVATE_KEY if absent.
VERIFIER_AGENT_PRIVATE_KEY=             # 0x... NEVER COMMIT

# -- AI ---------------------------------------------------------------------
HEURIST_API_KEY=                        # Get at https://heurist.ai

# -- Pricing (human-readable USDT amounts) ---------------------------------
INSTANT_SCAN_QUICK_PRICE=0
INSTANT_SCAN_STANDARD_PRICE=1
INSTANT_SCAN_DEEP_PRICE=3

# -- WalletConnect ----------------------------------------------------------
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=   # Free at https://cloud.walletconnect.com

# -- Database ---------------------------------------------------------------
DATABASE_URL=file:./dev.db              # SQLite dev. Use PostgreSQL URL for production.

# -- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
